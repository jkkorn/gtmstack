#!/usr/bin/env bash
# gtmstack CLI — books-as-evals runner for GTM specialists
# Thin bash wrapper around evals/runner.ts (TypeScript via bun)

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
RUNNER="$ROOT/evals/runner.ts"

if [[ ! -f "$RUNNER" ]]; then
  echo "ERROR: gtmstack runner not found at $RUNNER" >&2
  echo "Are you running from the gtmstack workspace root?" >&2
  exit 1
fi

if ! command -v bun >/dev/null 2>&1; then
  echo "ERROR: bun not found in PATH." >&2
  echo "Install bun: https://bun.sh/" >&2
  exit 1
fi

if ! command -v claude >/dev/null 2>&1; then
  echo "ERROR: claude CLI not found in PATH." >&2
  echo "Install Claude Code: https://claude.com/claude-code" >&2
  echo "(gtmstack runs analyses via headless Claude Code, not the Anthropic API.)" >&2
  exit 1
fi

exec bun run "$RUNNER" "$@"
